# Your TONE3000 publishable key (client_id) from Settings → API Keys.
# Safe to expose in the browser — this is a client-side OAuth (PKCE) integration.
NEXT_PUBLIC_TONE3000_CLIENT_ID=t3k_pub_your_key_here

# Optional: override the TONE3000 API origin (e.g. for local API dev).
# Defaults to https://www.tone3000.com
# NEXT_PUBLIC_T3K_API_DOMAIN=http://localhost:3000
